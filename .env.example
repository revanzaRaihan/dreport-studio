APP_NAME="Report Studio"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# SUPABASE (PostgreSQL) — isi dengan kredensial dari Supabase dashboard
# Dashboard → Project → Settings → Database → Connection string (URI mode)
# ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db.xxxxxxxxxxxx.supabase.co   # ganti dengan host Supabase kamu
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password  # ganti dengan password database Supabase
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=log

# ─────────────────────────────────────────────
# AI Provider Configuration
# Pilih: gemini atau groq
# ─────────────────────────────────────────────
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_API_KEY=                            # isi setelah login lewat Settings UI

# ─────────────────────────────────────────────
# Admin Login (dipakai oleh Seeder)
# Ubah sesuai kebutuhan, lalu jalankan: php artisan db:seed
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@reportstudio.test
ADMIN_PASSWORD=password

VITE_APP_NAME="${APP_NAME}"
